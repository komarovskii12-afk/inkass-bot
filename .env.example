# Скопируй в .env для локального запуска или задай как переменные окружения в Render.

# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# ID владельцев (тебя) — узнать через @userinfobot. Несколько через запятую.
ADMIN_IDS=111111111

# ID работников через запятую
WORKER_IDS=222222222,333333333

# Часовой пояс для дат отчёта
TIMEZONE=Europe/Moscow

# Пункты для первого запуска (создадутся автоматически, если база пустая)
DEFAULT_POINTS=Центр,Вокзал,Аэропорт

# --- Только для Render (webhook) ---
# URL сервиса на Render, например https://inkass-bot.onrender.com
BASE_WEBHOOK_URL=
# Придумай любую случайную строку
WEBHOOK_SECRET=change-me-please
# Строка подключения к PostgreSQL (Render подставит сам, если связать базу)
DATABASE_URL=

# Локально можно оставить DATABASE_URL пустым — будет SQLite (bot.db),
# и BASE_WEBHOOK_URL пустым — будет polling.
